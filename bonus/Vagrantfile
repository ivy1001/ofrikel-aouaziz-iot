Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"

  # VM name
  config.vm.hostname = "iot-bonus"

  # Resources (GitLab needs more RAM)
  config.vm.provider "virtualbox" do |vb|
    vb.memory = 8192
    vb.cpus = 4
  end

  # Sync the bonus folder into the VM
  config.vm.synced_folder ".", "/home/vagrant/iot"

  # Port forwarding to access services from host browser
  config.vm.network "forwarded_port", guest: 8080, host: 8080, auto_correct: true # ArgoCD
  config.vm.network "forwarded_port", guest: 8888, host: 8888, auto_correct: true # App
  config.vm.network "forwarded_port", guest: 8181, host: 8181, auto_correct: true # GitLab

  # Provision: install Docker + add vagrant user to docker group
  config.vm.provision "shell", inline: <<-SHELL
    sudo apt-get update -y
    sudo apt-get install -y git curl

    # Install Docker
    if ! command -v docker >/dev/null 2>&1; then
      curl -fsSL https://get.docker.com | sh
    fi
    sudo usermod -aG docker vagrant
    sudo systemctl enable --now docker
  SHELL
end
